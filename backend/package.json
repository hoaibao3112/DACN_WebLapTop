{
  "name": "laptop-shop-backend",
  "version": "1.0.0",
  "description": "Node.js Backend with Sequelize ORM for Laptop Shop Management System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:ai": "nodemon src/ai-server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ai\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:ai": "node dist/ai-server.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:ai\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nodejs",
    "express",
    "sequelize",
    "typescript",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "googleapis": "^170.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "mysql2": "^3.9.1",
    "natural": "^8.1.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "sequelize": "^6.37.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/natural": "^5.1.5",
    "@types/node": "^25.0.9",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^9.0.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
